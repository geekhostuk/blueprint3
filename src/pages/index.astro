---
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';
import BlueprintPanel from '../components/BlueprintPanel.astro';
import Button from '../components/Button.astro';
import Badge from '../components/Badge.astro';
import Card from '../components/Card.astro';
import SpecItem from '../components/SpecItem.astro';
import Input from '../components/Input.astro';
import Select from '../components/Select.astro';
import Textarea from '../components/Textarea.astro';

const specs = [
  { value: '±0.5mm', label: 'FDM tolerance' },
  { value: '24hr', label: 'Quoted within' },
  { value: '1', label: 'Minimum units' },
];

const promises = [
  {
    title: "We're here to help",
    body: "We offer a free 30-minute chat to go over your idea, sketch or model. If a design won't print well or would be cheaper another way, we'll advise on the best approach.",
  },
  {
    title: 'Every job, big or small, gets full attention',
    body: "Whether your job's big or small, simple or complex, we'll help. If it's important to you, it's important to us.",
  },
  {
    title: "We're with you until it's right",
    body: "Nothing is perfect first time, but we'll help you as best we can.",
  },
];

const faqs = [
  {
    q: "I don't have a CAD file. Can you still help?",
    a: "Yes, that's the service. Send a photo, a sketch, a rough description, or the broken part itself. We build the model from whatever you have.",
  },
  {
    q: "What's the smallest run you'll take?",
    a: "One. Low volume is the point. Ten units gets the same attention as a thousand, and you won't be pushed toward a minimum order you don't need.",
  },
  {
    q: 'How fast can I get a quote?',
    a: "Send over what you need and you'll have a quote within 24 hours, from the engineer doing the work, not an inbox.",
  },
  {
    q: 'What materials can you print?',
    a: 'FDM prints are made in PLA, PETG or TPU. Not sure which suits your needs? Tell us what and where it’s for and we can advise on what’s best. For outdoor or direct-sun use, PETG; for simple indoor parts, PLA; for flexible, rubber-like parts, TPU.',
  },
];

// Real work from Kai. Each card shows the graphic, then a tag, heading and
// one-line blurb. To add more, drop a file in public/assets/ and follow the
// same shape.
const caseStudies = [
  {
    tag: 'Idea to object',
    title: 'From sketch to printed award',
    blurb: 'A napkin sketch taken all the way to a full-colour, multi-part printed trophy.',
    image: '/assets/case-idea-to-model.png',
  },
  {
    tag: 'B2B',
    title: 'Custom 3D modelling',
    blurb: 'A bespoke component tray modelled from scratch to hold each part exactly where it needs to sit.',
    image: '/assets/case-custom-3d.png',
  },
  {
    tag: 'Reverse-engineered',
    title: 'Obsolete or unstocked parts',
    blurb: 'Discontinued and hard-to-find parts rebuilt from the broken originals and printed to fit.',
    image: '/assets/case-obsolete-parts.png',
  },
  {
    tag: 'Repairs',
    title: 'Repairs & replacement parts',
    blurb: 'Worn and broken parts remodelled and reprinted, from controller sticks to household fittings.',
    image: '/assets/case-repairs.png',
  },
];

const serviceOptions = ['3D CAD modelling', 'Printing from my file', 'Both (model and print)'];
const materials = ['Not sure yet', 'PLA', 'PETG', 'TPU'];

const description =
  'BluePrint3 is a small, high-quality, customer-focused 3D CAD modelling service for individuals, trade and B2B. We model your idea, then print it in PLA, PETG or TPU. Bring a sketch, a photo or a broken part and we’ll quote within 24 hours.';
---

<Layout title="BluePrint3 · Your idea, in your hands." description={description}>
  <a class="skip-link" href="#main">Skip to content</a>

  <!-- ===== Nav ===== -->
  <header class="nav">
    <div class="nav__inner">
      <a class="nav__brand" href="#top" aria-label="BluePrint3 · home">
        <Logo size={26} showMark markSrc="/assets/logo-cube.png" />
      </a>
      <nav class="nav__links" aria-label="Primary">
        <a href="#contact">Contact us</a>
        <a href="#services">Services</a>
        <a href="#work">Case studies</a>
        <a href="#why">Why us</a>
        <a href="#faq">FAQ</a>
      </nav>
      <div class="nav__cta">
        <Button variant="primary" size="sm" href="#contact">Get a quote</Button>
      </div>
    </div>
  </header>

  <main id="main">
    <!-- ===== Hero ===== -->
    <section id="top">
      <BlueprintPanel padding="clamp(44px, 7vw, 92px) 24px" radius="0px">
        <div class="hero">
          <span class="hero__eyebrow">3D CAD modelling &middot; individuals, trade &amp; B2B</span>
          <h1 class="hero__title">Your idea, in your hands.</h1>
          <p class="hero__lede">
            It starts as a sketch. It leaves as a thing.<br />
            <span class="nowrap">Idea &rarr; model &rarr; object</span><br />
            All under one roof. You don't need a print-ready file to begin.
          </p>
          <div class="hero__actions">
            <Button variant="onDark" size="lg" href="#contact">Get a quote</Button>
            <a class="hero__ghost" href="#services">See what's possible</a>
          </div>
        </div>
      </BlueprintPanel>
    </section>

    <!-- ===== Proof strip ===== -->
    <section class="proof" aria-label="Capabilities at a glance">
      <div class="proof__inner">
        {specs.map((s) => <SpecItem value={s.value} label={s.label} />)}
      </div>
    </section>

    <!-- ===== Services ===== -->
    <section id="services" class="services">
      <h2 class="section__title">Two services, one pipeline</h2>
      <p class="section__lede">
        You don't have to bring us a print-ready file, and you don't have to take a model elsewhere
        to get it made.
      </p>
      <div class="services__grid">
        <Card interactive>
          <Badge tone="brand">Step one</Badge>
          <h3 class="card__title">3D modelling</h3>
          <p class="card__body">
            Bring us a drawing, a photo, a rough description or a broken part, and we build the
            model.
          </p>
        </Card>
        <Card interactive>
          <Badge tone="brand">Step two</Badge>
          <h3 class="card__title">Prototyping &amp; low-volume printing</h3>
          <p class="card__body">
            We print it. One-offs, iterations and short production runs. Low volume is the point, not
            a limitation. Let's get your repair, fix or idea off the ground.
          </p>
        </Card>
      </div>
    </section>

    <!-- ===== Case studies ===== -->
    <section id="work" class="work">
      <div class="work__inner">
        <h2 class="section__title">Recent work</h2>
        <p class="section__lede">
          A few examples of what's possible, from a photo or a sketch to a finished part.
        </p>
        <div class="work__grid">
          {
            caseStudies.map((c) => (
              <Card interactive padding="0" class="work__card">
                {c.image ? (
                  <img class="work__media" src={c.image} alt={c.title} width="945" height="567" loading="lazy" />
                ) : (
                  <div class="work__media work__media--placeholder" aria-hidden="true">
                    <span>BluePrint3</span>
                  </div>
                )}
                <div class="work__text">
                  <Badge tone="brand">{c.tag}</Badge>
                  <h3 class="card__title">{c.title}</h3>
                  <p class="card__body">{c.blurb}</p>
                </div>
              </Card>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ===== Why us / the promise ===== -->
    <section id="why" class="why">
      <div class="why__inner">
        <h2 class="section__title">The engineer is the person you talk to.</h2>
        <p class="section__lede section__lede--wide">
          No middle man. You speak directly to the engineer doing the work, and you'll be kept
          informed of progress at every step, whatever your needs.
        </p>
        <div class="why__grid">
          {
            promises.map((p) => (
              <div>
                <h3 class="why__title">{p.title}</h3>
                <p class="why__body">{p.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ===== FAQ ===== -->
    <section id="faq" class="faq">
      <h2 class="section__title faq__title">Questions, answered</h2>
      {
        faqs.map((f) => (
          <details class="faq__item">
            <summary class="faq__q">{f.q}</summary>
            <p class="faq__a">{f.a}</p>
          </details>
        ))
      }
    </section>

    <!-- ===== Quote / contact form ===== -->
    <section id="contact" class="quote">
      <div class="quote__inner">
        <div id="quote-form-panel">
          <h2 class="quote__title">Tell us what you need made.</h2>
          <p class="quote__lede">
            Not sure what you need? Ask us. A sketch, a photo or a broken part is enough to start.
          </p>
          <Card padding="var(--space-6)">
            <form
              id="quote-form"
              class="form"
              action="/api/quote"
              method="POST"
              enctype="multipart/form-data"
            >
              <div class="form__row">
                <Input
                  id="name"
                  label="Your name"
                  placeholder="Jordan Ellery"
                  autocomplete="name"
                  required
                />
                <Input
                  id="email"
                  label="Your email"
                  type="email"
                  placeholder="you@example.com"
                  autocomplete="email"
                  required
                />
              </div>
              <div class="form__row">
                <Select id="service" label="Service" options={serviceOptions} />
                <Select id="material" label="Material" options={materials} />
              </div>
              <Textarea
                id="message"
                label="Let us know your idea"
                rows={5}
                placeholder="Please provide as much detail as possible, such as dimensions, overall size, quantity and what it's for."
                required
              />

              <div class="form__field">
                <label class="form__label" for="attachments">
                  Attachments <span class="form__optional">(optional)</span>
                </label>
                <input
                  id="attachments"
                  name="attachments"
                  class="form__file"
                  type="file"
                  multiple
                  accept="image/png,image/jpeg,image/webp,image/gif,.pdf,.stl,.step,.stp,.3mf,.obj"
                />
                <span class="form__hint">
                  Photos, sketches or CAD files. Up to 5 files, 10MB each.
                </span>
              </div>

              {/* Honeypot — bots fill it in, people never see it. */}
              <div class="form__trap" aria-hidden="true">
                <label for="company">Company</label>
                <input id="company" name="company" type="text" tabindex="-1" autocomplete="off" />
              </div>

              <p id="form-error" class="form__error" role="alert" hidden></p>

              <div class="form__actions">
                <Button id="quote-submit" variant="primary" size="lg" type="submit">
                  Send it over
                </Button>
                <span class="form__note">Quoted within 24 hours.</span>
              </div>
            </form>
          </Card>
        </div>

        <div id="quote-sent-panel" hidden>
          <BlueprintPanel padding="48px">
            <h2 class="sent__title" id="sent-heading" tabindex="-1">Got it.</h2>
            <p class="sent__body">
              We'll look at what you've sent and come back with a quote within 24 hours. You'll hear
              from the engineer doing the work, not an inbox.
            </p>
            <Button id="quote-reset" variant="onDark">Send another</Button>
          </BlueprintPanel>
        </div>
      </div>
    </section>
  </main>

  <!-- ===== Footer ===== -->
  <footer class="footer">
    <div class="footer__inner">
      <Logo size={20} />
      <span>Accessible manufacturing, done properly.</span>
      <span class="footer__right">Quoted within 24 hours &middot; Warm, plain, British.</span>
    </div>
  </footer>
</Layout>

<script>
  const form = document.querySelector<HTMLFormElement>('#quote-form');
  const formPanel = document.querySelector<HTMLElement>('#quote-form-panel');
  const sentPanel = document.querySelector<HTMLElement>('#quote-sent-panel');
  const sentHeading = document.querySelector<HTMLElement>('#sent-heading');
  const errorEl = document.querySelector<HTMLElement>('#form-error');
  const submitBtn = document.querySelector<HTMLButtonElement>('#quote-submit');
  const resetBtn = document.querySelector<HTMLButtonElement>('#quote-reset');
  const fileInput = document.querySelector<HTMLInputElement>('#attachments');

  // Kept in step with the server-side limits in src/pages/api/quote.ts.
  const MAX_FILES = 5;
  const MAX_FILE_BYTES = 10 * 1024 * 1024;
  const MAX_TOTAL_BYTES = 20 * 1024 * 1024;

  // Without JS the form posts natively and the endpoint redirects to /quote-sent.
  // With JS we submit in the background and swap in the success panel in place.
  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!form.reportValidity()) return;

    errorEl?.setAttribute('hidden', '');

    // Never show a raw exception message — every path here resolves to copy
    // written for the person reading it.
    const showError = (message: string) => {
      if (!errorEl) return;
      errorEl.textContent = message;
      errorEl.removeAttribute('hidden');
    };

    // Catch oversized attachments before uploading so the person gets an
    // instant, friendly message rather than waiting on a rejected upload.
    const files = fileInput?.files ? Array.from(fileInput.files) : [];
    if (files.length > MAX_FILES) {
      showError(`Please attach no more than ${MAX_FILES} files.`);
      return;
    }
    const oversized = files.find((f) => f.size > MAX_FILE_BYTES);
    if (oversized) {
      showError(`“${oversized.name}” is too large. Each file must be under 10MB.`);
      return;
    }
    if (files.reduce((sum, f) => sum + f.size, 0) > MAX_TOTAL_BYTES) {
      showError('Those attachments are too large. Please keep the total under 20MB.');
      return;
    }

    submitBtn?.setAttribute('disabled', '');
    const label = submitBtn?.textContent;
    if (submitBtn) submitBtn.textContent = 'Sending…';

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        headers: { Accept: 'application/json' },
        body: new FormData(form),
      });

      if (response.ok) {
        formPanel?.setAttribute('hidden', '');
        sentPanel?.removeAttribute('hidden');
        sentHeading?.focus();
      } else {
        // The endpoint's own message is already specific ("That email address
        // doesn't look right") — pass it through rather than talking over it.
        const data = (await response.json().catch(() => null)) as { error?: string } | null;
        showError(data?.error ?? 'We couldn’t send that just now. Please try again.');
      }
    } catch {
      // fetch only rejects on a network-level failure, so say so.
      showError('We couldn’t reach the server. Check your connection and try again.');
    } finally {
      submitBtn?.removeAttribute('disabled');
      if (submitBtn && label) submitBtn.textContent = label;
    }
  });

  resetBtn?.addEventListener('click', () => {
    form?.reset();
    sentPanel?.setAttribute('hidden', '');
    formPanel?.removeAttribute('hidden');
  });
</script>

<style>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    z-index: 100;
    background: var(--bp-white);
    color: var(--text-link);
    padding: var(--space-3) var(--space-4);
    font-weight: var(--fw-semibold);
  }

  .skip-link:focus {
    left: var(--space-4);
    top: var(--space-4);
  }

  /* ===== Nav ===== */
  .nav {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border-default);
  }

  .nav__inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 13px 24px;
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .nav__brand {
    display: flex;
    text-decoration: none;
  }

  .nav__links {
    display: flex;
    gap: 4px;
    margin-left: 8px;
  }

  .nav__links a {
    padding: 8px 12px;
    font-size: 15px;
    font-weight: var(--fw-semibold);
    color: var(--text-muted);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition:
      color var(--dur-fast) var(--ease-standard),
      background var(--dur-fast) var(--ease-standard);
  }

  .nav__links a:hover {
    color: var(--text-heading);
    background: var(--bp-ink-75);
  }

  .nav__cta {
    margin-left: auto;
  }

  @media (max-width: 640px) {
    .nav__inner {
      gap: 12px;
    }

    .nav__links {
      display: none;
    }
  }

  /* ===== Hero ===== */
  .hero {
    max-width: 1120px;
    margin: 0 auto;
  }

  .nowrap {
    white-space: nowrap;
  }

  .hero__eyebrow {
    font-size: 13px;
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    opacity: 0.85;
    font-weight: var(--fw-semibold);
  }

  .hero__title {
    font-size: clamp(36px, 5.5vw, 60px);
    font-weight: var(--fw-extrabold);
    letter-spacing: var(--ls-tight);
    line-height: 1.04;
    margin: 16px 0 0;
    max-width: 780px;
  }

  .hero__lede {
    font-size: clamp(17px, 2vw, 21px);
    opacity: 0.9;
    line-height: var(--lh-body);
    margin: 20px 0 0;
    max-width: 560px;
  }

  .hero__actions {
    display: flex;
    gap: 12px;
    margin-top: 34px;
    flex-wrap: wrap;
  }

  .hero__ghost {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 13px 28px;
    font-size: 18px;
    font-weight: var(--fw-semibold);
    color: #fff;
    text-decoration: none;
    border: 1.5px solid rgba(255, 255, 255, 0.4);
    border-radius: var(--radius-sm);
    transition:
      background var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }

  .hero__ghost:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.7);
  }

  /* ===== Proof strip ===== */
  .proof {
    border-bottom: 1px solid var(--border-default);
  }

  .proof__inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 44px 24px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  @media (max-width: 640px) {
    .proof__inner {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px 24px;
    }
  }

  /* ===== Shared section furniture ===== */
  .section__title {
    font-size: clamp(26px, 3.5vw, 34px);
    font-weight: var(--fw-extrabold);
    color: var(--text-heading);
    margin: 0 0 8px;
    letter-spacing: var(--ls-tight);
  }

  .section__lede {
    font-size: 17px;
    color: var(--text-muted);
    line-height: var(--lh-body);
    margin: 0 0 32px;
    max-width: 580px;
  }

  .section__lede--wide {
    margin-bottom: 36px;
    max-width: 620px;
  }

  /* ===== Services ===== */
  .services {
    max-width: 1120px;
    margin: 0 auto;
    padding: 72px 24px;
  }

  .services__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  @media (max-width: 760px) {
    .services__grid {
      grid-template-columns: 1fr;
    }
  }

  .card__title {
    font-size: 22px;
    font-weight: var(--fw-bold);
    color: var(--text-heading);
    margin: 14px 0 8px;
  }

  .card__body {
    font-size: 15px;
    color: var(--text-muted);
    line-height: var(--lh-body);
    margin: 0;
  }

  /* ===== Case studies ===== */
  .work {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 24px 72px;
  }

  .work__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  @media (max-width: 640px) {
    .work__grid {
      grid-template-columns: 1fr;
    }
  }

  /* Card padding is 0 so the media bleeds to the edges; text is padded below. */
  .work__card {
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* Graphics carry their own baked-in titles, so show them whole (contain,
     not crop) on a light surface — cropping would cut the headings and dark
     text on the dark grid would vanish. */
  .work__media {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: contain;
    background: var(--bp-white);
    border-bottom: 1px solid var(--border-default);
  }

  /* Placeholder tile: on-brand blueprint grid until a real photo is dropped in. */
  .work__media--placeholder {
    position: relative;
    display: grid;
    place-items: center;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.14) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.14) 1px, transparent 1px),
      var(--bp-grid-gradient);
    background-size:
      28px 28px,
      28px 28px,
      auto;
  }

  .work__media--placeholder span {
    font-size: 13px;
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.75);
  }

  .work__text {
    padding: var(--space-5);
  }

  .work__text .card__title {
    margin-top: 12px;
  }

  /* ===== Why ===== */
  .why {
    background: var(--surface-sunken);
    border-top: 1px solid var(--border-default);
    border-bottom: 1px solid var(--border-default);
  }

  .why__inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 72px 24px;
  }

  .why__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  @media (max-width: 760px) {
    .why__grid {
      grid-template-columns: 1fr;
    }
  }

  .why__title {
    font-size: 17px;
    font-weight: var(--fw-bold);
    color: var(--bp-navy);
    margin: 0 0 6px;
  }

  .why__body {
    font-size: 15px;
    color: var(--text-muted);
    line-height: var(--lh-body);
    margin: 0;
  }

  /* ===== FAQ ===== */
  .faq {
    max-width: 760px;
    margin: 0 auto;
    padding: 72px 24px;
  }

  .faq__title {
    margin-bottom: 28px;
  }

  .faq__item {
    border-bottom: 1px solid var(--border-default);
    padding: 18px 0;
  }

  .faq__q {
    font-size: 17px;
    font-weight: var(--fw-semibold);
    color: var(--text-heading);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .faq__q::-webkit-details-marker {
    display: none;
  }

  /* A drawn chevron rather than the default disclosure triangle. */
  .faq__q::after {
    content: '';
    flex: none;
    width: 9px;
    height: 9px;
    border-right: 2px solid var(--color-brand);
    border-bottom: 2px solid var(--color-brand);
    transform: translateY(-3px) rotate(45deg);
    transition: transform var(--dur-med) var(--ease-standard);
  }

  .faq__item[open] .faq__q::after {
    transform: translateY(2px) rotate(-135deg);
  }

  .faq__a {
    font-size: 15px;
    color: var(--text-muted);
    line-height: var(--lh-body);
    margin: 12px 0 0;
  }

  /* ===== Quote ===== */
  .quote {
    background: var(--surface-sunken);
