---
/** Checkbox with label. Brand blue when checked. */
interface Props {
  label: string;
  id: string;
  name?: string;
  checked?: boolean;
  disabled?: boolean;
  class?: string;
}

const { label, id, name, checked = false, disabled = false, class: className } = Astro.props;
---

<label class:list={['cb', className]} for={id}>
  <input
    id={id}
    name={name ?? id}
    type="checkbox"
    class="cb__input"
    checked={checked}
    disabled={disabled}
  />
  <span class="cb__box" aria-hidden="true">
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
      <path
        d="M2.5 6.2L4.8 8.5L9.5 3.5"
        stroke="#fff"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </span>
  <span class="cb__label">{label}</span>
</label>

<style>
  .cb {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--fs-body);
    color: var(--text-body);
    cursor: pointer;
  }

  .cb:has(.cb__input:disabled) {
    cursor: not-allowed;
    opacity: 0.5;
  }

  /* The real input stays in the layout (not display:none) so it remains
     focusable and reachable by assistive tech; the box is the visual. */
  .cb__input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .cb__box {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    border-radius: var(--radius-xs);
    border: 1.5px solid var(--border-strong);
    background: var(--surface-card);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition:
      background var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }

  .cb__box svg {
    opacity: 0;
    transition: opacity var(--dur-fast) var(--ease-standard);
  }

  .cb__input:checked + .cb__box {
    background: var(--color-brand);
    border-color: var(--color-brand);
  }

  .cb__input:checked + .cb__box svg {
    opacity: 1;
  }

  .cb__input:focus-visible + .cb__box {
    outline: 2px solid var(--border-focus);
    outline-offset: 2px;
  }
</style>
